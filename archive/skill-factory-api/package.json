{
  "name": "@skill-factory/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"console.log('@skill-factory/api built → dist/. Start: npm run dev:factory (root) or npm run start (here). If EADDRINUSE on 8787: lsof -iTCP:8787 -sTCP:LISTEN, kill PID')\"",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "dev:kill": "node scripts/kill-listen-port.mjs",
    "dev:force": "node scripts/kill-listen-port.mjs && tsx src/index.ts",
    "dev:factory": "npm run dev",
    "dev:factory:watch": "npm run dev:watch",
    "dev:factory:force": "npm run dev:force",
    "start": "node dist/index.js",
    "start:factory": "npm run start",
    "lint": "tsc -p tsconfig.json --noEmit",
    "smoke:intent": "tsx scripts/smoke-intent-phase3.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@skill-factory/shared": "*",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
